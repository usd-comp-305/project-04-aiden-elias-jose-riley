<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900" prefHeight="600"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.sandiego.comp305.project4pointofsale.ServerController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #2c3e50; -fx-padding: 12 16 12 16;">

            <Label text="🧑‍💼  Server Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

            <HBox HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="0" style="-fx-background-color: #ecf0f1;">

            <Label text="Open Orders"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;
                          -fx-background-color: #dfe6e9;
                          -fx-padding: 8 12 8 12; -fx-pref-width: infinity;"/>

            <ListView fx:id="ordersList"
                      VBox.vgrow="ALWAYS"
                      style="-fx-font-size: 13px;">
                <placeholder>
                    <Label text="No open orders"
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;"/>
                </placeholder>
            </ListView>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="20"
              style="-fx-background-color: #dfe6e9; -fx-padding: 12 16 12 16;">

            <Button text="🚪  Logout"
                    onAction="#handleLogout"
                    prefWidth="170"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>

            <Button text="＋  New Order"
                    onAction="#handleNewOrder"
                    prefWidth="170"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
        </HBox>
    </bottom>

</BorderPane>
