<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="root"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.sandiego.comp305.project4pointofsale.PaymentController"
      spacing="15"
      alignment="TOP_CENTER"
      prefWidth="500" prefHeight="450">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Payment"/>

    <Label fx:id="totalLabel" text="Total: $0.00"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Method:"/>
        <ComboBox fx:id="methodCombo" prefWidth="200" onAction="#handleMethodChange"/>
    </HBox>

    <VBox fx:id="cashPanel" spacing="5">
        <Label text="Cash Received:"/>
        <TextField fx:id="cashReceivedField" prefWidth="200"/>
    </VBox>

    <VBox fx:id="creditPanel" spacing="5" visible="false" managed="false">
        <Label text="Card Number:"/>
        <TextField fx:id="cardNumberField" prefWidth="200"/>
        <Label text="Cardholder Name:"/>
        <TextField fx:id="cardHolderField" prefWidth="200"/>
    </VBox>

    <VBox fx:id="mobilePanel" spacing="5" visible="false" managed="false">
        <Label text="Provider:"/>
        <TextField fx:id="providerField" prefWidth="200"/>
    </VBox>

    <Label fx:id="resultLabel" text=""/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Back" onAction="#handleBack"/>
        <Button text="Confirm Payment" onAction="#handleConfirm"/>
    </HBox>
</VBox>
