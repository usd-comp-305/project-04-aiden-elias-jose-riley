<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="600" prefHeight="500"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.sandiego.comp305.project4pointofsale.PaymentController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #2c3e50; -fx-padding: 12 16 12 16;">

            <Label text="💳  Payment"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

            <HBox HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14"
              style="-fx-background-color: #ecf0f1;">
            <padding>
                <Insets top="20" right="30" bottom="10" left="30"/>
            </padding>

            <Label fx:id="totalLabel" text="Total: $0.00"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Payment Method:"
                       style="-fx-font-size: 14px; -fx-text-fill: #2c3e50; -fx-font-weight: bold;"/>
                <ComboBox fx:id="methodCombo" prefWidth="220"
                          style="-fx-font-size: 13px;"/>
            </HBox>

            <VBox fx:id="cashPanel" spacing="6">
                <Label text="Cash Received ($):"
                       style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;"/>
                <TextField fx:id="cashReceivedField"
                           promptText="Enter amount"
                           style="-fx-font-size: 13px; -fx-padding: 6 10;
                                  -fx-pref-width: 220; -fx-background-color: white;
                                  -fx-border-color: #bdc3c7; -fx-border-radius: 4;
                                  -fx-background-radius: 4;"/>
            </VBox>

            <VBox fx:id="creditPanel" spacing="6" visible="false" managed="false">
                <Label text="Card Number:"
                       style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;"/>
                <TextField fx:id="cardNumberField"
                           promptText="XXXX XXXX XXXX XXXX"
                           style="-fx-font-size: 13px; -fx-padding: 6 10;
                                  -fx-pref-width: 280; -fx-background-color: white;
                                  -fx-border-color: #bdc3c7; -fx-border-radius: 4;
                                  -fx-background-radius: 4;"/>
                <Label text="Cardholder Name:"
                       style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;"/>
                <TextField fx:id="cardHolderField"
                           promptText="Full name"
                           style="-fx-font-size: 13px; -fx-padding: 6 10;
                                  -fx-pref-width: 280; -fx-background-color: white;
                                  -fx-border-color: #bdc3c7; -fx-border-radius: 4;
                                  -fx-background-radius: 4;"/>
            </VBox>

            <VBox fx:id="mobilePanel" spacing="6" visible="false" managed="false">
                <Label text="Mobile Provider:"
                       style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;"/>
                <TextField fx:id="providerField"
                           promptText="e.g. Apple Pay, Google Pay"
                           style="-fx-font-size: 13px; -fx-padding: 6 10;
                                  -fx-pref-width: 260; -fx-background-color: white;
                                  -fx-border-color: #bdc3c7; -fx-border-radius: 4;
                                  -fx-background-radius: 4;"/>
            </VBox>

            <Label fx:id="resultLabel" text=""
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #27ae60;
                          -fx-wrap-text: true;"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="20"
              style="-fx-background-color: #dfe6e9; -fx-padding: 12 16 12 16;">

            <Button text="← Back"
                    onAction="#handleBack"
                    prefWidth="170"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>

            <Button text="✔  Confirm Payment"
                    onAction="#handleConfirm"
                    prefWidth="200"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
        </HBox>
    </bottom>

</BorderPane>
