<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="500" prefHeight="340"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.sandiego.comp305.project4pointofsale.HelloController">

    <top>
        <HBox alignment="CENTER"
              style="-fx-background-color: #2c3e50; -fx-padding: 12 16 12 16;">

            <Label text="🍴  Restaurant POS System"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20"
              style="-fx-background-color: #ecf0f1;">
            <padding>
                <Insets top="30" right="40" bottom="20" left="40"/>
            </padding>

            <Label fx:id="welcomeText"
                   text="Welcome to the Restaurant POS"
                   style="-fx-font-size: 16px; -fx-text-fill: #2c3e50;
                          -fx-font-weight: bold; -fx-wrap-text: true;
                          -fx-text-alignment: center;"/>

            <Button text="Get Started"
                    onAction="#onHelloButtonClick"
                    prefWidth="170"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color: #dfe6e9; -fx-padding: 10 16 10 16;">
            <Label text="POS System v1.0"
                   style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
        </HBox>
    </bottom>

</BorderPane>
