<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900" prefHeight="600"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.sandiego.comp305.project4pointofsale.ChefController">

    <!-- Header bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #2c3e50; -fx-padding: 12 16 12 16;">

            <Label text="👨‍🍳  Chef Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

            <!-- Spacer pushes buttons to the right -->
            <HBox HBox.hgrow="ALWAYS"/>

            <Button text="⟳  Refresh"
                    onAction="#handleRefresh"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-cursor: hand;"/>

            <Button text="← Back"
                    onAction="#handleBack"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- SplitPane: ticket queue (left) / detail panel (right) -->
    <center>
        <SplitPane dividerPositions="0.33"
                   style="-fx-background-color: #ecf0f1;">

            <VBox spacing="0" style="-fx-background-color: #f8f9fa;">

                <Label text="Open Tickets"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;
                              -fx-background-color: #dfe6e9;
                              -fx-padding: 8 12 8 12; -fx-pref-width: infinity;"/>

                <ListView fx:id="ticketListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="10" style="-fx-background-color: #ffffff;">
                <padding>
                    <Insets top="14" right="16" bottom="14" left="16"/>
                </padding>

                <!-- Order summary row -->
                <Label fx:id="orderInfoLabel"
                       text="Select a ticket to view details."
                       style="-fx-font-size: 14px; -fx-text-fill: #2c3e50;
                              -fx-font-weight: bold; -fx-wrap-text: true;"/>

                <Label fx:id="statusLabel"
                       text=""
                       style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>

                <Label text="Order Items"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: #555555; -fx-padding: 4 0 0 0;"/>

                <ListView fx:id="orderItemsListView"
                          prefHeight="180"
                          style="-fx-font-size: 13px;"/>

                <Label fx:id="ingredientsTitleLabel"
                       text="Ingredients  (select a menu item above)"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: #555555; -fx-padding: 4 0 0 0;"/>

                <ListView fx:id="ingredientsListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-font-size: 13px;"/>
            </VBox>

        </SplitPane>
    </center>

    <!-- Action buttons -->
    <bottom>
        <HBox alignment="CENTER" spacing="20"
              style="-fx-background-color: #dfe6e9; -fx-padding: 12 16 12 16;">

            <Button fx:id="startTicketButton"
                    text="▶  Start Ticket"
                    onAction="#handleStartTicket"
                    prefWidth="170"
                    style="-fx-background-color: #e67e22; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>

            <Button fx:id="markReadyButton"
                    text="✔  Mark Ready"
                    onAction="#handleMarkReady"
                    prefWidth="170"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>

            <Button fx:id="markDeliveredButton"
                    text="🚀  Mark Delivered"
                    onAction="#handleMarkDelivered"
                    prefWidth="170"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>

        </HBox>
    </bottom>

</BorderPane>
